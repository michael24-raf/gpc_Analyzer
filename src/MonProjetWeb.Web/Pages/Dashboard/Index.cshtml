@page "/Dashboard"
@model MonProjetWeb.Web.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "Tableau de bord";
    ViewData["Page"]  = "Dashboard";
}

@* Messages *@
@if (Model.SuccessMessage != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (Model.ErrorMessage != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* ── Barre d'actions ──────────────────────────────────────────────────── *@
<div class="card border-0 shadow-sm rounded-3 p-3 mb-4">
    <div class="d-flex flex-wrap gap-2 align-items-center">
        <span class="fw-semibold text-muted me-2">
            <i class="bi bi-lightning-fill text-warning"></i> Actions rapides :
        </span>

        <form method="post" asp-page-handler="SyncGcp" class="d-inline">
            <button type="submit" class="btn btn-primary btn-sm">
                <i class="bi bi-cloud-download me-1"></i> Synchroniser GCP
            </button>
        </form>

        <form method="post" asp-page-handler="SyncBudgets" class="d-inline">
            <button type="submit" class="btn btn-info btn-sm text-white">
                <i class="bi bi-wallet2 me-1"></i> Sync Budgets
            </button>
        </form>

        <form method="post" asp-page-handler="CheckAlerts" class="d-inline">
            <button type="submit" class="btn btn-warning btn-sm">
                <i class="bi bi-bell me-1"></i> Vérifier Budgets
            </button>
        </form>

        <form method="post" asp-page-handler="DetectAnomalies" class="d-inline">
            <button type="submit" class="btn btn-danger btn-sm">
                <i class="bi bi-search me-1"></i> Détecter Anomalies
            </button>
        </form>

        <form method="post" asp-page-handler="GenerateRecommendations" class="d-inline">
            <button type="submit" class="btn btn-success btn-sm">
                <i class="bi bi-lightbulb me-1"></i> Générer Recommandations
            </button>
        </form>
    </div>
</div>

@* ── KPI Cards ── *@